import { currentUser, db, nextId, userById } from "@/lib/db"
import type { DocFile } from "@/lib/types"

export const dynamic = "force-dynamic"

// GET /api/documents?workspaceId=&projectId= — list documents in scope.
export async function GET(request: Request) {
  const { searchParams } = new URL(request.url)
  const workspaceId = searchParams.get("workspaceId")
  const projectId = searchParams.get("projectId")
  let docs = db.documents
  if (workspaceId) docs = docs.filter((d) => d.workspaceId === workspaceId)
  if (projectId) docs = docs.filter((d) => d.projectId === projectId)
  else if (workspaceId) docs = docs.filter((d) => !d.projectId)
  return Response.json(
    docs
      .sort((a, b) => b.createdAt.localeCompare(a.createdAt))
      .map((d) => ({
        ...d,
        dataUrl: undefined, // omit payload from listing
        uploadedBy: userById(d.uploadedById)?.name,
      }))
  )
}

// POST /api/documents — upload one or more files (base64 data URLs).
// Supports directory uploads: the client sends relative paths as the name.
export async function POST(request: Request) {
  const user = currentUser()
  const body = (await request.json()) as {
    workspaceId?: string
    projectId?: string
    files?: { name: string; mimeType: string; size: number; dataUrl: string }[]
  }
  if (!body.workspaceId || !body.files?.length) {
    return Response.json(
      { error: "workspaceId and files are required" },
      { status: 400 }
    )
  }
  const created: DocFile[] = body.files.map((f) => {
    const doc: DocFile = {
      id: nextId("doc"),
      name: f.name,
      mimeType: f.mimeType || "application/octet-stream",
      size: f.size,
      dataUrl: f.dataUrl,
      workspaceId: body.workspaceId!,
      projectId: body.projectId,
      uploadedById: user.id,
      createdAt: new Date().toISOString(),
    }
    db.documents.push(doc)
    return doc
  })
  return Response.json(
    { count: created.length, ids: created.map((d) => d.id) },
    { status: 201 }
  )
}
