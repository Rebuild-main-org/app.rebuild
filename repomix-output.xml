<file path="app/api/workspaces/[id]/members/route.ts">
import { db, nextId } from "@/lib/db"
import { membersForWorkspace } from "@/lib/queries"
import type { Role } from "@/lib/types"

export async function GET(
  _request: Request,
  { params }: { params: Promise<{ id: string }> }
) {
  const { id } = await params
  return Response.json(membersForWorkspace(id))
}

export async function POST(
  request: Request,
  { params }: { params: Promise<{ id: string }> }
) {
  const { id } = await params
  const { email, role } = (await request.json()) as {
    email?: string
    role?: Role
  }
  if (!email) {
    return Response.json({ error: "email is required" }, { status: 400 })
  }
  let user = db.users.find((u) => u.email.toLowerCase() === email.toLowerCase())
  if (!user) {
    user = {
      id: nextId("u"),
      email,
      name: email.split("@")[0],
      role: role ?? "ENGINEER",
    }
    db.users.push(user)
  }
  const existing = db.members.find(
    (m) => m.userId === user!.id && m.workspaceId === id
  )
  if (existing) {
    return Response.json({ error: "Already a member" }, { status: 409 })
  }
  const member = {
    id: nextId("m"),
    userId: user.id,
    workspaceId: id,
    role: role ?? "ENGINEER",
    joinedAt: new Date().toISOString(),
  }
  db.members.push(member)
  return Response.json({ ...member, user }, { status: 201 })
}
</file>

<file path="app/api/workspaces/[id]/messages/route.ts">
import { currentUser, db, nextId, userById } from "@/lib/db"
import { emit } from "@/lib/events"

export async function GET(
  _request: Request,
  { params }: { params: Promise<{ id: string }> }
) {
  const { id } = await params
  const messages = db.messages
    .filter((m) => m.workspaceId === id)
    .sort((a, b) => a.createdAt.localeCompare(b.createdAt))
    .map((m) => ({ ...m, author: userById(m.authorId) }))
  return Response.json(messages)
}

export async function POST(
  request: Request,
  { params }: { params: Promise<{ id: string }> }
) {
  const { id } = await params
  const { content } = (await request.json()) as { content?: string }
  if (!content?.trim()) {
    return Response.json({ error: "content is required" }, { status: 400 })
  }
  const user = currentUser()
  const message = {
    id: nextId("msg"),
    content: content.trim(),
    authorId: user.id,
    workspaceId: id,
    isFromClient: user.role === "CLIENT",
    createdAt: new Date().toISOString(),
  }
  db.messages.push(message)
  const withAuthor = { ...message, author: user }
  emit(`ws:${id}`, "message.created", { message: withAuthor }, user.id)
  return Response.json(withAuthor, { status: 201 })
}
