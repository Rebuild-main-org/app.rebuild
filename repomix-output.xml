<file path="lib/analytics.ts">
// Analytics computations (spec §13) over the data store.

import { db } from "./db"
import { ticketsForWorkspace } from "./queries"

const WEEK = 7 * 86_400_000

export interface GlobalAnalytics {
  activeWorkspaces: number
  activeProjects: number
  totalOpenTickets: number
  loadPerEngineer: number
  onTimeRate: number // % milestones delivered on/before due
  createdThisWeek: number
  resolvedThisWeek: number
}

export function globalAnalytics(): GlobalAnalytics {
  const activeWorkspaces = db.workspaces.filter((w) => w.status === "ACTIVE").length
  const activeProjects = db.projects.filter((p) => p.status === "ACTIVE").length
  const open = db.tickets.filter((t) => t.status !== "DONE")
  const engineers = db.users.filter((u) => u.role === "ENGINEER").length || 1

  const milestones = db.milestones.filter((m) => m.done)
  const onTime = milestones.filter(
    (m) => !m.validatedAt || new Date(m.validatedAt) <= new Date(m.dueDate)
  ).length
  const onTimeRate = milestones.length
    ? Math.round((onTime / milestones.length) * 100)
    : 100

  const now = Date.now()
  const createdThisWeek = db.tickets.filter(
    (t) => now - new Date(t.createdAt).getTime() <= WEEK
  ).length
  const resolvedThisWeek = db.tickets.filter(
    (t) => t.status === "DONE" && now - new Date(t.updatedAt).getTime() <= WEEK
  ).length

  return {
    activeWorkspaces,
    activeProjects,
    totalOpenTickets: open.length,
    loadPerEngineer: Math.round((open.length / engineers) * 10) / 10,
    onTimeRate,
    createdThisWeek,
    resolvedThisWeek,
  }
}

export interface EngineerStat {
  userId: string
  name: string
  assigned: number
  completed: number
  open: number
  points: number // delivered story points
}

export function engineerStats(): EngineerStat[] {
  return db.users
    .filter((u) => u.role === "ENGINEER" || u.role === "LEAD")
    .map((u) => {
      const mine = db.tickets.filter((t) => t.assigneeId === u.id)
      const completed = mine.filter((t) => t.status === "DONE")
      return {
        userId: u.id,
        name: u.name,
        assigned: mine.length,
        completed: completed.length,
        open: mine.filter((t) => t.status !== "DONE").length,
        points: completed.reduce((s, t) => s + (t.points ?? 0), 0),
      }
    })
    .filter((s) => s.assigned > 0)
}

export interface WorkspaceStat {
  workspaceId: string
  name: string
  bugs: number
  features: number
  velocity: number // delivered points
  milestonesOnTime: number
  milestonesLate: number
}

export function workspaceStats(): WorkspaceStat[] {
  return db.workspaces.map((w) => {
    const tickets = ticketsForWorkspace(w.id)
    const projectIds = new Set(
      db.projects.filter((p) => p.workspaceId === w.id).map((p) => p.id)
    )
    const milestones = db.milestones.filter((m) => projectIds.has(m.projectId))
    return {
      workspaceId: w.id,
      name: w.name,
      bugs: tickets.filter((t) => t.type === "BUG").length,
      features: tickets.filter((t) => t.type === "FEATURE").length,
      velocity: tickets
        .filter((t) => t.status === "DONE")
        .reduce((s, t) => s + (t.points ?? 0), 0),
      milestonesOnTime: milestones.filter(
        (m) => m.done && (!m.validatedAt || new Date(m.validatedAt) <= new Date(m.dueDate))
      ).length,
      milestonesLate: milestones.filter(
        (m) => !m.done && new Date(m.dueDate) < new Date()
      ).length,
    }
  })
}
