<file path="components/ide/terminal.tsx">
"use client"

import { useEffect, useRef } from "react"
import { useTheme } from "next-themes"
import "@xterm/xterm/css/xterm.css"

import type { RepoFile } from "@/lib/types"

// A simulated shell. A real terminal needs node-pty in a sandboxed Docker
// container (spec §07) which isn't available here, so a small set of commands
// is emulated client-side against the in-memory repo.
export function Terminal({
  repo,
  branch,
}: {
  repo: Pick<RepoFile, "path" | "content">[]
  branch: string
}) {
  const containerRef = useRef<HTMLDivElement>(null)
  const { resolvedTheme } = useTheme()

  useEffect(() => {
    let term: import("@xterm/xterm").Terminal | undefined
    let disposed = false
    let line = ""
    let onResize: (() => void) | undefined

    async function init() {
      const { Terminal } = await import("@xterm/xterm")
      const { FitAddon } = await import("@xterm/addon-fit")
      if (disposed || !containerRef.current) return

      const dark = resolvedTheme === "dark"
      term = new Terminal({
        fontSize: 13,
        fontFamily: "var(--font-mono), monospace",
        cursorBlink: true,
        theme: dark
          ? { background: "#0a0a0a", foreground: "#e5e5e5" }
          : { background: "#ffffff", foreground: "#171717" },
      })
      const fit = new FitAddon()
      term.loadAddon(fit)
      term.open(containerRef.current)
      fit.fit()

      const prompt = () => term!.write("\r\n\x1b[32mrebuild\x1b[0m:~/repo$ ")
      term.writeln("REBUILD sandboxed terminal — simulated shell")
      term.writeln('Type "help" for available commands.')
      prompt()

      const run = (raw: string) => {
        const [cmd, ...args] = raw.trim().split(/\s+/)
        switch (cmd) {
          case "":
            break
          case "help":
            term!.writeln(
              "Commands: ls, cat <file>, pwd, git status, git branch, npm run <script>, echo, clear"
            )
            break
          case "ls":
            term!.writeln(
              Array.from(new Set(repo.map((f) => f.path.split("/")[0]))).join(
                "  "
              )
            )
            break
          case "pwd":
            term!.writeln("/home/rebuild/repo")
            break
          case "cat": {
            const file = repo.find((f) => f.path === args[0])
            if (file) file.content.split("\n").forEach((l) => term!.writeln(l))
            else term!.writeln(`cat: ${args[0] ?? ""}: No such file`)
            break
          }
          case "echo":
            term!.writeln(args.join(" "))
            break
          case "git":
            if (args[0] === "status") {
              term!.writeln(`On branch ${branch}`)
              term!.writeln('Changes not staged for commit:')
              term!.writeln("  (use the commit box in the IDE to commit)")
            } else if (args[0] === "branch") {
              term!.writeln(`* ${branch}`)
            } else {
              term!.writeln(`git: '${args[0] ?? ""}' is not supported here`)
            }
            break
          case "npm":
            if (args[0] === "run") {
              term!.writeln(`> ${args[1] ?? "dev"}`)
              term!.writeln("simulated: build completed in 1.2s ✓")
            } else {
              term!.writeln("npm: only 'run' is simulated")
            }
            break
          case "clear":
            term!.clear()
            break
          default:
            term!.writeln(`command not found: ${cmd}`)
        }
      }

      term.onData((data) => {
        if (!term) return
        if (data === "\r") {
          term.writeln("")
          run(line)
          line = ""
          prompt()
        } else if (data === "\x7f") {
          // backspace
          if (line.length > 0) {
            line = line.slice(0, -1)
            term.write("\b \b")
          }
        } else if (data >= " ") {
          line += data
          term.write(data)
        }
      })

      onResize = () => fit.fit()
      window.addEventListener("resize", onResize)
    }

    init()
    return () => {
      disposed = true
      if (onResize) window.removeEventListener("resize", onResize)
      term?.dispose()
    }
  }, [repo, branch, resolvedTheme])

  return <div ref={containerRef} className="size-full" />
}
</file>

<file path="components/layout/app-shell.tsx">
"use client"

import { useMemo, useState } from "react"
import Link from "next/link"
import { usePathname, useRouter } from "next/navigation"
import { useTheme } from "next-themes"
import { toast } from "sonner"

import { useRealtime } from "@/hooks/use-realtime"
import { can, roleAtLeast } from "@/lib/auth"
import { Copilot } from "@/components/ai/copilot"
import {
  BarChart3,
  Bell,
  Boxes,
  Calendar,
  FileBarChart,
  FileText,
  GitBranch,
  LayoutDashboard,
  type LucideIcon,
  MessageSquare,
  Moon,
  Settings,
  Sun,
  TerminalSquare,
  KanbanSquare,
} from "lucide-react"

import type { Notification, User, Workspace } from "@/lib/types"
import { cn } from "@/lib/utils"
import { RoleBadge, UserAvatar } from "@/components/shared/badges"
import { Button } from "@/components/ui/button"
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuLabel,
  DropdownMenuSeparator,
  DropdownMenuTrigger,
} from "@/components/ui/dropdown-menu"
import { ScrollArea } from "@/components/ui/scroll-area"

interface NavItem {
  href: string
  label: string
  icon: LucideIcon
}

function NavLink({ item, active }: { item: NavItem; active: boolean }) {
  const Icon = item.icon
  return (
    <Link
      href={item.href}
      className={cn(
        "flex items-center gap-2.5 rounded-md px-3 py-2 text-sm transition-colors",
        active
          ? "bg-sidebar-accent text-sidebar-accent-foreground font-medium"
          : "text-sidebar-foreground/70 hover:bg-sidebar-accent/50 hover:text-sidebar-foreground"
      )}
    >
      <Icon className="size-4 shrink-0" />
      {item.label}
    </Link>
  )
}

export function AppShell({
  user,
  workspaces,
  notifications,
  children,
}: {
  user: User
  workspaces: Workspace[]
  notifications: Notification[]
  children: React.ReactNode
}) {
  const pathname = usePathname()

  // Derive the active workspace from the URL: /workspace/[id]/...
  const wsMatch = pathname.match(/^\/workspace\/([^/]+)/)
  const activeWsId = wsMatch?.[1]
  const activeWs = workspaces.find((w) => w.id === activeWsId)

  const globalNav: NavItem[] = [
    { href: "/dashboard", label: "Dashboard", icon: LayoutDashboard },
    { href: "/workspaces", label: "Workspaces", icon: Boxes },
    ...(roleAtLeast(user.role, "LEAD")
      ? [
          { href: "/analytics", label: "Analytics", icon: BarChart3 },
          { href: "/reports", label: "Reports", icon: FileBarChart },
        ]
      : []),
  ]

  const wsNav: NavItem[] = activeWs
    ? [
        { href: `/workspace/${activeWs.id}/overview`, label: "Overview", icon: LayoutDashboard },
        { href: `/workspace/${activeWs.id}/projects`, label: "Projects", icon: KanbanSquare },
        { href: `/workspace/${activeWs.id}/ide`, label: "IDE", icon: TerminalSquare },
        { href: `/workspace/${activeWs.id}/git`, label: "Git & CI/CD", icon: GitBranch },
        { href: `/workspace/${activeWs.id}/chat`, label: "Team Chat", icon: MessageSquare },
        { href: `/workspace/${activeWs.id}/documents`, label: "Documents", icon: FileText },
        { href: `/workspace/${activeWs.id}/calendar`, label: "Calendar", icon: Calendar },
        { href: `/workspace/${activeWs.id}/settings`, label: "Settings", icon: Settings },
      ]
    : []

  return (
    <div className="flex h-svh overflow-hidden bg-background">
      {/* Sidebar */}
      <aside className="bg-sidebar text-sidebar-foreground hidden w-60 shrink-0 flex-col border-r md:flex">
        <div className="flex h-14 items-center gap-2 border-b px-4">
          <div className="bg-primary text-primary-foreground flex size-7 items-center justify-center rounded font-bold">
            R
          </div>
          <div className="leading-tight">
            <div className="text-sm font-semibold">REBUILD</div>
            <div className="text-muted-foreground text-[10px]">Engineering OS</div>
          </div>
        </div>

        <ScrollArea className="flex-1">
          <nav className="space-y-1 p-3">
            {globalNav.map((item) => (
              <NavLink
                key={item.href}
                item={item}
                active={pathname === item.href || pathname.startsWith(item.href + "/")}
              />
            ))}
          </nav>

          {activeWs && (
            <div className="px-3 pb-3">
              <div className="text-muted-foreground px-3 pb-1 text-[11px] font-medium tracking-wide uppercase">
                {activeWs.name}
              </div>
              <nav className="space-y-1">
                {wsNav.map((item) => (
                  <NavLink
                    key={item.href}
                    item={item}
                    active={pathname.startsWith(item.href)}
                  />
                ))}
              </nav>
            </div>
          )}
        </ScrollArea>
      </aside>

      {/* Main column */}
      <div className="flex min-w-0 flex-1 flex-col">
        <Topbar user={user} notifications={notifications} />
        <main className="flex-1 overflow-y-auto">{children}</main>
      </div>
      {can(user, "copilot.use") && <Copilot />}
    </div>
  )
}

function Topbar({
  user,
  notifications,
}: {
  user: User
  notifications: Notification[]
}) {
  const router = useRouter()
  const { resolvedTheme, setTheme } = useTheme()
  const [items, setItems] = useState(notifications)
  const unread = items.filter((n) => !n.read)

  // Live notifications pushed to this user's room.
  useRealtime(useMemo(() => [`user:${user.id}`], [user.id]), (event) => {
    if (event.type !== "notification") return
    const { notification } = event.payload as { notification: Notification }
    setItems((prev) =>
      prev.some((n) => n.id === notification.id)
        ? prev
        : [notification, ...prev]
    )
    toast(notification.content)
  })

  async function markAllRead() {
    if (unread.length === 0) return
    setItems((prev) => prev.map((n) => ({ ...n, read: true })))
    await fetch("/api/notifications", {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ all: true }),
    })
  }

  async function switchUser(userId: string) {
    await fetch("/api/auth/login", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ userId }),
    })
    router.refresh()
  }

  async function logout() {
    await fetch("/api/auth/logout", { method: "POST" })
    router.push("/login")
  }

  return (
    <header className="flex h-14 shrink-0 items-center justify-between border-b px-4 md:px-6">
      <div className="text-muted-foreground text-sm">
        Build faster. Scale smarter.
      </div>

      <div className="flex items-center gap-1">
        {/* Notifications */}
        <DropdownMenu
          onOpenChange={(open) => {
            if (!open) markAllRead()
          }}
        >
          <DropdownMenuTrigger asChild>
            <Button variant="ghost" size="icon" className="relative">
              <Bell className="size-4" />
              {unread.length > 0 && (
                <span className="bg-destructive text-destructive-foreground absolute -top-0.5 -right-0.5 flex size-4 items-center justify-center rounded-full text-[9px] font-semibold">
                  {unread.length}
                </span>
              )}
              <span className="sr-only">Notifications</span>
            </Button>
          </DropdownMenuTrigger>
          <DropdownMenuContent align="end" className="w-80">
            <DropdownMenuLabel>
              Notifications {unread.length > 0 && `(${unread.length} new)`}
            </DropdownMenuLabel>
            <DropdownMenuSeparator />
            {items.length === 0 && (
              <div className="text-muted-foreground px-2 py-6 text-center text-sm">
                You&apos;re all caught up.
              </div>
            )}
            {items.slice(0, 8).map((n) => (
              <DropdownMenuItem key={n.id} asChild>
                <Link href={n.linkUrl ?? "#"} className="flex flex-col items-start gap-0.5">
                  <span className={cn("text-sm", !n.read && "font-medium")}>
                    {n.content}
                  </span>
                  <span className="text-muted-foreground text-[11px]">
                    {new Date(n.createdAt).toLocaleString()}
                  </span>
                </Link>
              </DropdownMenuItem>
            ))}
          </DropdownMenuContent>
        </DropdownMenu>

        {/* Theme toggle */}
        <Button
          variant="ghost"
          size="icon"
          onClick={() => setTheme(resolvedTheme === "dark" ? "light" : "dark")}
        >
          <Sun className="size-4 dark:hidden" />
          <Moon className="hidden size-4 dark:block" />
          <span className="sr-only">Toggle theme</span>
        </Button>

        {/* User menu / role switcher */}
        <DropdownMenu>
          <DropdownMenuTrigger asChild>
            <Button variant="ghost" className="gap-2 pl-1.5">
              <UserAvatar name={user.name} />
              <div className="hidden text-left leading-tight sm:block">
                <div className="text-sm font-medium">{user.name}</div>
              </div>
            </Button>
          </DropdownMenuTrigger>
          <DropdownMenuContent align="end" className="w-56">
            <DropdownMenuLabel className="flex items-center justify-between">
              {user.name} <RoleBadge role={user.role} />
            </DropdownMenuLabel>
            <div className="text-muted-foreground px-2 pb-1 text-xs">
              {user.email}
            </div>
            <DropdownMenuSeparator />
            <DropdownMenuItem asChild>
              <Link href="/profile">Profile</Link>
            </DropdownMenuItem>
            <DropdownMenuItem asChild>
              <Link href="/settings">Settings</Link>
            </DropdownMenuItem>
            {can(user, "admin.panel") && (
              <DropdownMenuItem asChild>
                <Link href="/admin">Admin panel</Link>
              </DropdownMenuItem>
            )}
            <DropdownMenuSeparator />
            <DropdownMenuLabel className="text-muted-foreground text-[11px] font-normal">
              Switch role (demo)
            </DropdownMenuLabel>
            <DropdownMenuItem onClick={() => switchUser("u_admin")}>
              Aziz Ghedamsi · Admin
            </DropdownMenuItem>
            <DropdownMenuItem onClick={() => switchUser("u_lead")}>
              Sami Karoui · Lead
            </DropdownMenuItem>
            <DropdownMenuItem onClick={() => switchUser("u_eng1")}>
              Nour Belhadj · Engineer
            </DropdownMenuItem>
            <DropdownMenuSeparator />
            <DropdownMenuItem onClick={logout}>Log out</DropdownMenuItem>
          </DropdownMenuContent>
        </DropdownMenu>
      </div>
    </header>
  )
}
</file>

