<file path="app/api/workspaces/route.ts">
import { currentUser, db, nextId } from "@/lib/db"
import { workspacesForUser } from "@/lib/queries"
import type { Workspace } from "@/lib/types"

export async function GET() {
  const user = currentUser()
  return Response.json(workspacesForUser(user.id))
}

export async function POST(request: Request) {
  const user = currentUser()
  if (user.role !== "ADMIN") {
    return Response.json({ error: "Forbidden" }, { status: 403 })
  }
  const body = (await request.json()) as Partial<Workspace>
  if (!body.name) {
    return Response.json({ error: "name is required" }, { status: 400 })
  }
  const slug =
    body.slug ?? body.name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "")
  const workspace: Workspace = {
    id: nextId("ws"),
    name: body.name,
    slug,
    githubRepo: body.githubRepo ?? `rebuild-tn/${slug}`,
    status: body.status ?? "ACTIVE",
    clientName: body.clientName ?? body.name,
    clientEmail: body.clientEmail ?? "",
    startDate: new Date().toISOString(),
    technologies: body.technologies ?? [],
  }
  db.workspaces.push(workspace)
  db.members.push({
    id: nextId("m"),
    userId: user.id,
    workspaceId: workspace.id,
    role: "ADMIN",
    joinedAt: workspace.startDate,
  })
  return Response.json(workspace, { status: 201 })
}
