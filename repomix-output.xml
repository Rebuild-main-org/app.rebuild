<file path="components/ide/ide-copilot.tsx">
"use client"

import { useRef, useState } from "react"
import { Send, Sparkles } from "lucide-react"

import { cn } from "@/lib/utils"
import { Button } from "@/components/ui/button"
import { Input } from "@/components/ui/input"

interface Msg {
  role: "user" | "assistant"
  content: string
}

// Copilot embedded in the IDE bottom frame (alongside Terminal & Preview).
// It's aware of the file currently open in the editor and the active branch.
export function IdeCopilot({
  workspaceId,
  branch,
  activePath,
  getActiveContent,
}: {
  workspaceId: string
  branch: string
  activePath: string | null
  getActiveContent: () => string | undefined
}) {
  const [messages, setMessages] = useState<Msg[]>([])
  const [draft, setDraft] = useState("")
  const [busy, setBusy] = useState(false)
  const endRef = useRef<HTMLDivElement>(null)

  async function send(text?: string) {
    const message = (text ?? draft).trim()
    if (!message || busy) return
    setDraft("")
    const next = [...messages, { role: "user" as const, content: message }]
    setMessages(next)
    setBusy(true)
    queueMicrotask(() => endRef.current?.scrollIntoView({ behavior: "smooth" }))

    const content = getActiveContent()
    const extraContext = activePath
      ? `Open file: ${activePath} (branch ${branch})\n\`\`\`\n${(content ?? "").slice(0, 3500)}\n\`\`\``
      : `Branch: ${branch}. No file open.`

    try {
      const res = await fetch("/api/ai/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          message,
          history: messages.slice(-6),
          page: "IDE",
          workspaceId,
          extraContext,
        }),
      })
      const data = await res.json()
      setMessages([
        ...next,
        { role: "assistant", content: res.ok ? data.reply : data.error ?? "Error." },
      ])
    } catch {
      setMessages([...next, { role: "assistant", content: "Network error." }])
    } finally {
      setBusy(false)
      queueMicrotask(() => endRef.current?.scrollIntoView({ behavior: "smooth" }))
    }
  }

  const suggestions = activePath
    ? ["Explain this file", "Find bugs in this file", "Suggest a refactor"]
    : ["What does this repo do?", "How do I run the tests?"]

  return (
    <div className="flex h-full flex-col">
      <div className="flex-1 space-y-2.5 overflow-y-auto p-3">
        {messages.length === 0 && (
          <div className="text-muted-foreground space-y-2 text-xs">
            <div className="flex items-center gap-1.5">
              <Sparkles className="text-primary size-3.5" />
              Copilot — {activePath ? `editing ${activePath.split("/").pop()}` : "ready"}
            </div>
            <div className="flex flex-wrap gap-1.5">
              {suggestions.map((s) => (
                <button
                  key={s}
                  onClick={() => send(s)}
                  className="hover:bg-muted rounded-full border px-2 py-0.5"
                >
                  {s}
                </button>
              ))}
            </div>
          </div>
        )}
        {messages.map((m, i) => (
          <div
            key={i}
            className={cn("flex", m.role === "user" ? "justify-end" : "justify-start")}
          >
            <div
              className={cn(
                "max-w-[88%] rounded-lg px-2.5 py-1.5 text-xs whitespace-pre-wrap",
                m.role === "user" ? "bg-primary text-primary-foreground" : "bg-muted"
              )}
            >
              {m.content}
            </div>
          </div>
        ))}
        {busy && <div className="text-muted-foreground text-xs">Thinking…</div>}
        <div ref={endRef} />
      </div>
      <form
        className="flex gap-2 border-t p-2"
        onSubmit={(e) => {
          e.preventDefault()
          send()
        }}
      >
        <Input
          value={draft}
          onChange={(e) => setDraft(e.target.value)}
          placeholder={activePath ? `Ask about ${activePath.split("/").pop()}…` : "Ask the Copilot…"}
          className="h-8 text-sm"
        />
        <Button type="submit" size="icon" className="size-8" disabled={busy || !draft.trim()}>
          <Send className="size-4" />
        </Button>
      </form>
    </div>
  )
}
