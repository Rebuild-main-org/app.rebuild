<file path="components/board/kanban-board.tsx">
"use client"

import { useCallback, useMemo, useState } from "react"
import { Plus } from "lucide-react"
import { toast } from "sonner"

import {
  STATUS_LABELS,
  TICKET_STATUSES,
  TYPE_META,
  type Ticket,
  type TicketStatus,
  type TicketType,
  type User,
} from "@/lib/types"
import { cn } from "@/lib/utils"
import { useRealtime } from "@/hooks/use-realtime"
import { PresenceBar } from "@/components/realtime/presence-bar"
import { TicketCard } from "@/components/board/ticket-card"
import { TicketDialog } from "@/components/board/ticket-dialog"
import { CreateTicketDialog } from "@/components/board/create-ticket-dialog"
import { Button } from "@/components/ui/button"
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select"

// Columns flagged as overloaded past this many cards (spec: overload indicator).
const WIP_LIMIT: Partial<Record<TicketStatus, number>> = {
  IN_PROGRESS: 3,
  IN_REVIEW: 3,
}

export function KanbanBoard({
  projectId,
  initialTickets,
  users,
  canDelete,
  currentUserId,
}: {
  projectId: string
  initialTickets: Ticket[]
  users: Pick<User, "id" | "name">[]
  canDelete: boolean
  currentUserId: string
}) {
  const [tickets, setTickets] = useState(initialTickets)
  const [selected, setSelected] = useState<string | null>(null)
  const [createIn, setCreateIn] = useState<TicketStatus | null>(null)
  const [dragId, setDragId] = useState<string | null>(null)
  const [filterAssignee, setFilterAssignee] = useState("all")
  const [filterType, setFilterType] = useState("all")
  const [presence, setPresence] = useState<
    { userId: string; name: string }[]
  >([])

  const userName = useMemo(
    () => new Map(users.map((u) => [u.id, u])),
    [users]
  )

  const refetch = useCallback(async () => {
    const res = await fetch(`/api/projects/${projectId}/tickets`)
    if (res.ok) setTickets(await res.json())
  }, [projectId])

  const room = `project:${projectId}`
  useRealtime(useMemo(() => [room], [room]), (event) => {
    if (event.type === "presence") {
      const p = event.payload as { users: { userId: string; name: string }[] }
      setPresence(p.users)
      return
    }
    if (
      event.type === "ticket.created" ||
      event.type === "ticket.updated" ||
      event.type === "board.reordered"
    ) {
      refetch()
      // Surface teammates' changes (not echoes of my own actions).
      if (event.actorId && event.actorId !== currentUserId) {
        const who = userName.get(event.actorId)?.name ?? "A teammate"
        if (event.type === "ticket.created")
          toast.info(`${who} created a ticket`)
        else if (event.type === "board.reordered")
          toast.info(`${who} moved a ticket`)
      }
    }
  })

  const filtered = tickets.filter(
    (t) =>
      (filterAssignee === "all" || t.assigneeId === filterAssignee) &&
      (filterType === "all" || t.type === filterType)
  )

  const byStatus = (status: TicketStatus) =>
    filtered
      .filter((t) => t.status === status)
      .sort((a, b) => a.order - b.order)

  async function moveTo(status: TicketStatus) {
    if (!dragId) return
    const moving = tickets.find((t) => t.id === dragId)
    setDragId(null)
    if (!moving || moving.status === status) return

    // Optimistic local update
    const updated = tickets.map((t) =>
      t.id === dragId ? { ...t, status, order: Number.MAX_SAFE_INTEGER } : t
    )
    setTickets(updated)

    await fetch(`/api/tickets/${dragId}`, {
      method: "PATCH",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ status }),
    })
    const orderedIds = updated
      .filter((t) => t.status === status)
      .sort((a, b) => a.order - b.order)
      .map((t) => t.id)
    await fetch(`/api/projects/${projectId}/reorder`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ status, orderedIds }),
    })
    refetch()
  }

  return (
    <div className="flex h-full flex-col">
      {/* Filter toolbar */}
      <div className="flex flex-wrap items-center gap-2 px-4 py-3 md:px-6">
        <span className="text-muted-foreground text-xs">Filter</span>
        <Select value={filterAssignee} onValueChange={setFilterAssignee}>
          <SelectTrigger size="sm" className="w-40">
            <SelectValue placeholder="Assignee" />
          </SelectTrigger>
          <SelectContent>
            <SelectItem value="all">All assignees</SelectItem>
            {users.map((u) => (
              <SelectItem key={u.id} value={u.id}>
                {u.name}
              </SelectItem>
            ))}
          </SelectContent>
        </Select>
        <Select value={filterType} onValueChange={setFilterType}>
          <SelectTrigger size="sm" className="w-32">
            <SelectValue placeholder="Type" />
          </SelectTrigger>
          <SelectContent>
            <SelectItem value="all">All types</SelectItem>
            {(Object.keys(TYPE_META) as TicketType[]).map((t) => (
              <SelectItem key={t} value={t}>
                {TYPE_META[t].label}
              </SelectItem>
            ))}
          </SelectContent>
        </Select>
        <div className="flex-1" />
        <PresenceBar users={presence} selfId={currentUserId} className="mr-2" />
        <Button size="sm" onClick={() => setCreateIn("BACKLOG")}>
          <Plus className="size-4" /> New ticket
        </Button>
      </div>

      {/* Columns */}
      <div className="flex flex-1 gap-3 overflow-x-auto px-4 pb-4 md:px-6">
        {TICKET_STATUSES.map((status) => {
          const items = byStatus(status)
          const limit = WIP_LIMIT[status]
          const overloaded = limit != null && items.length > limit
          return (
            <div
              key={status}
              onDragOver={(e) => e.preventDefault()}
              onDrop={() => moveTo(status)}
              className="bg-muted/40 flex w-72 shrink-0 flex-col rounded-lg"
            >
              <div className="flex items-center justify-between px-3 py-2.5">
                <div className="flex items-center gap-2">
                  <span className="text-sm font-medium">
                    {STATUS_LABELS[status]}
                  </span>
                  <span
                    className={cn(
                      "rounded-full px-1.5 text-xs",
                      overloaded
                        ? "bg-red-500/15 text-red-600 dark:text-red-400"
                        : "bg-muted-foreground/15 text-muted-foreground"
                    )}
                  >
                    {items.length}
                  </span>
                </div>
                <Button
                  size="icon"
                  variant="ghost"
                  className="size-6"
                  onClick={() => setCreateIn(status)}
                >
                  <Plus className="size-3.5" />
                </Button>
              </div>
              <div className="flex flex-1 flex-col gap-2 px-2 pb-2">
                {items.map((t) => (
                  <TicketCard
                    key={t.id}
                    ticket={t}
                    assignee={userName.get(t.assigneeId ?? "")}
                    onClick={() => setSelected(t.id)}
                    onDragStart={() => setDragId(t.id)}
                  />
                ))}
                {items.length === 0 && (
                  <div className="text-muted-foreground/60 px-2 py-6 text-center text-xs">
                    Drop here
                  </div>
                )}
              </div>
            </div>
          )
        })}
      </div>

      <TicketDialog
        ticketId={selected}
        users={users}
        canDelete={canDelete}
        onClose={() => setSelected(null)}
        onChanged={refetch}
      />

      {createIn && (
        <CreateTicketDialog
          projectId={projectId}
          users={users}
          defaultStatus={createIn}
          open={!!createIn}
          onOpenChange={(o) => !o && setCreateIn(null)}
          onCreated={() => refetch()}
        />
      )}
    </div>
  )
}
</file>

