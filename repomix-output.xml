export function nextId(prefix: string): string {
  db.seq += 1
  return `${prefix}_${db.seq}`
}

export function currentUser(): User {
  return db.users.find((u) => u.id === db.currentUserId) ?? db.users[0]
}

export function userById(id?: string): User | undefined {
  return id ? db.users.find((u) => u.id === id) : undefined
}

export function getPreferences(userId: string): UserPreferences {
  const existing = db.preferences.find((p) => p.userId === userId)
  if (existing) return existing
  return {
    userId,
    theme: "system",
    density: "comfortable",
    language: "en",
    accent: "#0a0a0a",
    emailDigest: true,
  }
}

export function savePreferences(
  userId: string,
  patch: Partial<UserPreferences>
): UserPreferences {
  let pref = db.preferences.find((p) => p.userId === userId)
  if (!pref) {
    pref = getPreferences(userId)
    db.preferences.push(pref)
  }
  Object.assign(pref, patch, { userId })
  return pref
}
