<file path="lib/ai.ts">
// AI layer (spec §09). Uses the real Claude API when ANTHROPIC_API_KEY is set,
// otherwise falls back to deterministic heuristic output so the UI works
// offline. Swap is transparent to callers.

import Anthropic from "@anthropic-ai/sdk"

const MODEL = process.env.AI_MODEL ?? "claude-opus-4-8"

let client: Anthropic | null = null
export function aiEnabled(): boolean {
  return !!process.env.ANTHROPIC_API_KEY
}
function getClient(): Anthropic | null {
  if (!aiEnabled()) return null
  if (!client) client = new Anthropic()
  return client
}

// A stable, cache-friendly system prompt prefix per task (see prompt-caching).
function systemBlocks(text: string) {
  return [{ type: "text" as const, text, cache_control: { type: "ephemeral" as const } }]
}

async function completeText(system: string, user: string, maxTokens = 1024) {
  const c = getClient()
  if (!c) return null
  try {
    const res = await c.messages.create({
      model: MODEL,
      max_tokens: maxTokens,
      thinking: { type: "adaptive" },
      system: systemBlocks(system),
      messages: [{ role: "user", content: user }],
    })
    return res.content
      .map((b) => (b.type === "text" ? b.text : ""))
      .join("")
      .trim()
  } catch {
    return null
  }
}

// --- Code review -------------------------------------------------------------

export type ReviewScore = "A" | "B" | "C" | "D"
export interface ReviewFinding {
  severity: "info" | "warning" | "critical"
  title: string
  detail: string
}
export interface CodeReview {
  score: ReviewScore
  summary: string
  findings: ReviewFinding[]
  generatedBy: "claude" | "heuristic"
}

const REVIEW_SCHEMA = {
  type: "object",
  additionalProperties: false,
  properties: {
    score: { type: "string", enum: ["A", "B", "C", "D"] },
    summary: { type: "string" },
    findings: {
      type: "array",
      items: {
        type: "object",
        additionalProperties: false,
        properties: {
          severity: { type: "string", enum: ["info", "warning", "critical"] },
          title: { type: "string" },
          detail: { type: "string" },
        },
        required: ["severity", "title", "detail"],
      },
    },
  },
  required: ["score", "summary", "findings"],
} as const

export async function codeReview(input: {
  title: string
  diff: string
  ticket?: string
}): Promise<CodeReview> {
  const c = getClient()
  if (c) {
    try {
      const res = await c.messages.create({
        model: MODEL,
        max_tokens: 2048,
        thinking: { type: "adaptive" },
        system: systemBlocks(
          "You are a senior engineer doing a non-blocking PR review. Flag potential bugs, security issues, convention violations, and improvements. Be concise and specific. Grade overall quality A (excellent) to D (needs work)."
        ),
        messages: [
          {
            role: "user",
            content: `PR: ${input.title}${input.ticket ? ` (ticket ${input.ticket})` : ""}\n\nDiff/code:\n${input.diff}`,
          },
        ],
        output_config: { format: { type: "json_schema", schema: REVIEW_SCHEMA } },
      })
      const text = res.content
        .map((b) => (b.type === "text" ? b.text : ""))
        .join("")
      const parsed = JSON.parse(text) as Omit<CodeReview, "generatedBy">
      return { ...parsed, generatedBy: "claude" }
    } catch {
      // fall through to heuristic
    }
  }
  return heuristicReview(input)
}

function heuristicReview(input: { title: string; diff: string }): CodeReview {
  const findings: ReviewFinding[] = []
  const diff = input.diff
  if (/console\.(log|debug)/.test(diff))
    findings.push({ severity: "warning", title: "Leftover console statements", detail: "Remove debug logging before merging." })
  if (/\bany\b/.test(diff))
    findings.push({ severity: "info", title: "Use of `any`", detail: "Prefer precise types over `any` where feasible." })
  if (/TODO|FIXME/.test(diff))
    findings.push({ severity: "info", title: "Unresolved TODO/FIXME", detail: "Track outstanding work in a ticket." })
  if (/password|secret|token/i.test(diff) && /=\s*["']/.test(diff))
    findings.push({ severity: "critical", title: "Possible hard-coded secret", detail: "Move secrets to environment variables." })
  if (!/test|spec/i.test(diff))
    findings.push({ severity: "info", title: "No tests in this change", detail: "Consider adding coverage for the new behaviour." })
  const score: ReviewScore = findings.some((f) => f.severity === "critical")
    ? "C"
    : findings.length > 2
      ? "B"
      : "A"
  return {
    score,
    summary: `Heuristic review of "${input.title}": ${findings.length} observation(s). Set ANTHROPIC_API_KEY for a full AI review.`,
    findings,
    generatedBy: "heuristic",
  }
}

// --- Documentation -----------------------------------------------------------

export async function generateDocs(input: {
  path: string
  code: string
}): Promise<string> {
  const out = await completeText(
    "You generate clear technical documentation. Produce concise Markdown: a one-line summary, key responsibilities, and JSDoc/docstring suggestions for exported symbols. No preamble.",
    `File: ${input.path}\n\n${input.code}`,
    1500
  )
  if (out) return out
  return `## ${input.path}\n\n_Heuristic summary (set ANTHROPIC_API_KEY for AI docs)._\n\nThis file exports ${(input.code.match(/export\s+(function|const|class|interface|type)\s+(\w+)/g) ?? [])
    .map((m) => m.split(/\s+/).pop())
    .join(", ") || "no top-level symbols"}.`
}

// --- Contextual chat (Copilot) ----------------------------------------------

export interface ChatTurn {
  role: "user" | "assistant"
  content: string
}

export async function chat(input: {
  context: string
  history: ChatTurn[]
  message: string
}): Promise<string> {
  const c = getClient()
  if (c) {
    try {
      const res = await c.messages.create({
        model: MODEL,
        max_tokens: 1500,
        thinking: { type: "adaptive" },
        system: systemBlocks(
          `You are the in-app Copilot for REBUILD Engineering OS — a platform for managing software projects (workspaces, projects, tickets, IDE, git). Help engineers and leads with the current context. Be concise and actionable.\n\nCurrent context:\n${input.context}`
        ),
        messages: [
          ...input.history.map((t) => ({ role: t.role, content: t.content })),
          { role: "user" as const, content: input.message },
        ],
      })
      return res.content
        .map((b) => (b.type === "text" ? b.text : ""))
        .join("")
        .trim()
    } catch {
      // fall through
    }
  }
  return `I'm the Copilot, but no Claude API key is configured yet. Add \`ANTHROPIC_API_KEY\` to \`.env.local\` to enable real answers.\n\nContext I can see:\n${input.context}`
}

// --- Summaries ---------------------------------------------------------------

export async function summarize(input: {
  kind: "project" | "sprint" | "ticket"
  content: string
}): Promise<string> {
  const out = await completeText(
    `You summarise ${input.kind} status for a busy reader in plain language. 3-5 sentences, no jargon, highlight what's done, in progress, and at risk.`,
    input.content,
    800
  )
  return out ?? `Summary unavailable offline. Set ANTHROPIC_API_KEY to enable AI summaries.\n\nRaw context:\n${input.content.slice(0, 500)}…`
}
