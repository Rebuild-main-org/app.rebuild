<file path="app/api/ai/review/route.ts">
import { db, userById } from "@/lib/db"
import { codeReview } from "@/lib/ai"
import { repoFiles } from "@/lib/queries"

// POST /api/ai/review — AI code review for a PR. Builds a diff from the
// workspace's changed repo files (the working set behind the PR).
export async function POST(request: Request) {
  const { wsId, prNumber } = (await request.json()) as {
    wsId?: string
    prNumber?: number
  }
  if (!wsId) return Response.json({ error: "wsId required" }, { status: 400 })

  const pr = db.prs.find((p) => p.workspaceId === wsId && p.number === prNumber)
  const title = pr?.title ?? "Working changes"
  const ticket = pr?.ticketId
    ? db.tickets.find((t) => t.id === pr.ticketId)?.shortId
    : undefined

  // Construct a diff-like payload from changed files.
  const changed = repoFiles(wsId).filter((f) => f.status !== "unmodified")
  const diff =
    changed.length > 0
      ? changed
          .map(
            (f) =>
              `--- ${f.path} (${f.status})\n${f.originalContent ? `# before\n${f.originalContent}\n` : ""}# after\n${f.content}`
          )
          .join("\n\n")
          .slice(0, 12000)
      : "No working changes detected; reviewing PR metadata only."

  const review = await codeReview({ title, diff, ticket })
  return Response.json({
    review,
    pr: pr ? { number: pr.number, title: pr.title, author: userById(pr.authorId)?.name } : null,
  })
}
</file>

<file path="app/api/ai/summary/route.ts">
import { db } from "@/lib/db"
import { summarize } from "@/lib/ai"
import { getProject, ticketsForProject } from "@/lib/queries"
import { STATUS_LABELS } from "@/lib/types"

// POST /api/ai/summary — AI summary of a project or sprint.
export async function POST(request: Request) {
  const { kind, projectId } = (await request.json()) as {
    kind?: "project" | "sprint"
    projectId?: string
  }
  if (!projectId) return Response.json({ error: "projectId required" }, { status: 400 })
  const project = getProject(projectId)
  if (!project) return Response.json({ error: "Not found" }, { status: 404 })

  const tickets = ticketsForProject(projectId)
  const lines = tickets.map(
    (t) => `- [${STATUS_LABELS[t.status]}] ${t.shortId} ${t.title} (${t.priority}${t.points ? `, ${t.points}pts` : ""})`
  )
  const milestones = db.milestones
    .filter((m) => m.projectId === projectId)
    .map((m) => `- ${m.title}: due ${new Date(m.dueDate).toLocaleDateString()}${m.done ? " (done)" : ""}`)

  const content = `Project: ${project.name} (status ${project.status})\nDescription: ${project.description}\n\nTickets:\n${lines.join("\n")}\n\nMilestones:\n${milestones.join("\n")}`

  const summary = await summarize({ kind: kind ?? "project", content })
  return Response.json({ summary })
}
</file>

