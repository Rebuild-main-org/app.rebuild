// Automated report generation (spec §13): weekly, sprint and release reports.

import { db, userById } from "./db"
import { ticketsForWorkspace } from "./queries"
import { STATUS_LABELS } from "./types"

const WEEK = 7 * 86_400_000
const STALE = 5 * 86_400_000

export type ReportType = "weekly" | "sprint" | "release"

export interface ReportSection {
  heading: string
  lines: string[]
}
export interface Report {
  type: ReportType
  title: string
  generatedAt: string
  sections: ReportSection[]
}

export function generateReport(type: ReportType, workspaceId: string): Report {
  const ws = db.workspaces.find((w) => w.id === workspaceId)
  const now = Date.now()
  const generatedAt = new Date().toISOString()
  const base = `${ws?.name ?? "Workspace"}`

  if (type === "weekly") {
    const tickets = ticketsForWorkspace(workspaceId)
    const completed = tickets.filter(
      (t) => t.status === "DONE" && now - new Date(t.updatedAt).getTime() <= WEEK
    )
    const inProgress = tickets.filter((t) => t.status === "IN_PROGRESS")
    const blocked = tickets.filter(
      (t) =>
        t.status !== "DONE" && now - new Date(t.updatedAt).getTime() > STALE
    )
    const points = completed.reduce((s, t) => s + (t.points ?? 0), 0)
    return {
      type,
      title: `Weekly report — ${base}`,
      generatedAt,
      sections: [
        { heading: `Completed this week (${completed.length})`, lines: completed.map((t) => `${t.shortId} ${t.title}`) },
        { heading: `In progress (${inProgress.length})`, lines: inProgress.map((t) => `${t.shortId} ${t.title} — ${userById(t.assigneeId)?.name ?? "unassigned"}`) },
        { heading: `Possibly blocked (${blocked.length})`, lines: blocked.map((t) => `${t.shortId} ${t.title} — no movement in 5+ days`) },
        { heading: "Velocity", lines: [`${points} story points delivered this week`] },
      ],
    }
  }

  if (type === "sprint") {
    const sprint = db.sprints
      .filter((s) => db.projects.some((p) => p.id === s.projectId && p.workspaceId === workspaceId))
      .sort((a, b) => b.startDate.localeCompare(a.startDate))[0]
    if (!sprint) {
      return { type, title: `Sprint report — ${base}`, generatedAt, sections: [{ heading: "No sprint found", lines: [] }] }
    }
    const tickets = db.tickets.filter((t) => t.sprintId === sprint.id)
    const done = tickets.filter((t) => t.status === "DONE")
    const carried = tickets.filter((t) => t.status !== "DONE")
    return {
      type,
      title: `Sprint report — ${sprint.name}`,
      generatedAt,
      sections: [
        { heading: "Sprint goal", lines: [sprint.goal] },
        { heading: `Completed (${done.length})`, lines: done.map((t) => `${t.shortId} ${t.title}`) },
        { heading: `Carried over (${carried.length})`, lines: carried.map((t) => `${t.shortId} ${t.title} (${STATUS_LABELS[t.status]})`) },
        { heading: "Outcome", lines: [carried.length === 0 ? "Sprint goal achieved ✓" : `${done.length}/${tickets.length} tickets completed`] },
      ],
    }
  }

  // release
  const deploy = db.deployments
    .filter((d) => d.workspaceId === workspaceId && d.env === "PRODUCTION")
    .sort((a, b) => b.deployedAt.localeCompare(a.deployedAt))[0]
  const mergedPrs = db.prs.filter((p) => p.workspaceId === workspaceId && p.status === "MERGED")
  const ticketsDelivered = mergedPrs
    .map((p) => db.tickets.find((t) => t.id === p.ticketId))
    .filter((t): t is NonNullable<typeof t> => !!t)
  return {
    type: "release",
    title: `Release report — ${base}`,
    generatedAt,
    sections: [
      { heading: "Latest production deploy", lines: deploy ? [`${deploy.commitHash} on ${new Date(deploy.deployedAt).toLocaleString()} by ${userById(deploy.authorId)?.name}`] : ["No production deploy yet"] },
      { heading: `Changelog (${mergedPrs.length} merged PRs)`, lines: mergedPrs.map((p) => `#${p.number} ${p.title}`) },
      { heading: `Features & fixes delivered (${ticketsDelivered.length})`, lines: ticketsDelivered.map((t) => `${t.shortId} ${t.title}`) },
    ],
  }
}

export function reportToMarkdown(r: Report): string {
  return [
    `# ${r.title}`,
    `_Generated ${new Date(r.generatedAt).toLocaleString()}_`,
    "",
    ...r.sections.flatMap((s) => [
      `## ${s.heading}`,
      ...(s.lines.length ? s.lines.map((l) => `- ${l}`) : ["_none_"]),
      "",
    ]),
  ].join("\n")
}
</file>

<file path="lib/supabase.ts">
// Supabase clients (env-driven). Real data path activates when the Supabase
// env vars are present; the app otherwise runs on the in-memory store.
//
//   NEXT_PUBLIC_SUPABASE_URL        project URL (used by both server & browser)
//   NEXT_PUBLIC_SUPABASE_ANON_KEY   anon key (browser, RLS-enforced)
//   SUPABASE_SERVICE_ROLE_KEY       service role key (server only, bypasses RLS)
//
// Apply supabase/schema.sql then supabase/seed.sql to provision the database.

import { createClient, type SupabaseClient } from "@supabase/supabase-js"

const url = process.env.NEXT_PUBLIC_SUPABASE_URL
const anonKey = process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY
const serviceKey = process.env.SUPABASE_SERVICE_ROLE_KEY

export function supabaseEnabled(): boolean {
  return !!(url && serviceKey)
}

let admin: SupabaseClient | null = null
/** Server-side client with the service role key. Use only in route handlers
 *  and server components — never ship the service key to the browser. */
export function supabaseAdmin(): SupabaseClient {
  if (!url || !serviceKey) {
    throw new Error(
      "Supabase not configured — set NEXT_PUBLIC_SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY"
    )
  }
  if (!admin) {
    admin = createClient(url, serviceKey, {
      auth: { persistSession: false, autoRefreshToken: false },
    })
  }
  return admin
}

let browser: SupabaseClient | null = null
/** Browser client with the anon key (RLS-enforced). */
export function supabaseBrowser(): SupabaseClient {
  if (!url || !anonKey) {
    throw new Error("Supabase public env vars are not set")
  }
  if (!browser) browser = createClient(url, anonKey)
  return browser
}
