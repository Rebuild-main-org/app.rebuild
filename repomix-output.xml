// Write operations against the in-memory store, with activity + audit logging.

import { currentUser, db, nextId } from "./db"
import { emit } from "./events"
import type {
  Activity,
  ActivityKind,
  Branch,
  Comment,
  GitCommit,
  Notification,
  Project,
  RepoFile,
  Ticket,
  TicketStatus,
} from "./types"

function workspaceRoomsForProject(projectId: string): string[] {
  const project = db.projects.find((p) => p.id === projectId)
  return [
    `project:${projectId}`,
    ...(project ? [`ws:${project.workspaceId}`] : []),
  ]
}

// Records a notification and pushes it live to the recipient's user room.
export function createNotification(
  userId: string,
  type: string,
  content: string,
  linkUrl?: string
): Notification {
  const notification: Notification = {
    id: nextId("n"),
    type,
    content,
    userId,
    read: false,
    createdAt: new Date().toISOString(),
    linkUrl,
  }
  db.notifications.push(notification)
  emit(`user:${userId}`, "notification", { notification })
  return notification
}

function ticketLink(ticket: Ticket): string {
  const project = db.projects.find((p) => p.id === ticket.projectId)
  return project
    ? `/workspace/${project.workspaceId}/projects/${ticket.projectId}/board`
    : "/dashboard"
}

function logActivity(
  ticketId: string,
  kind: ActivityKind,
  message: string
): Activity {
  const activity: Activity = {
    id: nextId("a"),
    ticketId,
    kind,
    actorId: currentUser().id,
    message,
    createdAt: new Date().toISOString(),
  }
  db.activities.push(activity)
  return activity
}

function audit(action: string, entityType: string, entityId: string) {
  db.auditLogs.push({
    id: nextId("audit"),
    action,
    entityType,
    entityId,
    userId: currentUser().id,
    createdAt: new Date().toISOString(),
  })
}

export function createTicket(
  projectId: string,
  input: Partial<Ticket> & Pick<Ticket, "title" | "type" | "priority">
): Ticket {
  const project = db.projects.find((p) => p.id === projectId)!
  const projectTickets = db.tickets.filter((t) => t.projectId === projectId)
  const maxNum = projectTickets.reduce((max, t) => {
    const n = Number(t.shortId.split("-")[1] ?? 0)
    return Math.max(max, Number.isNaN(n) ? 0 : n)
  }, 100)
  const now = new Date().toISOString()
  const ticket: Ticket = {
    id: nextId("t"),
    shortId: `${project.shortCode}-${maxNum + 1}`,
    title: input.title,
    description: input.description ?? "",
    type: input.type,
    priority: input.priority,
    status: input.status ?? "BACKLOG",
    projectId,
    assigneeId: input.assigneeId,
    reporterId: currentUser().id,
    labels: input.labels ?? [],
    epicId: input.epicId,
    milestoneId: input.milestoneId,
    sprintId: input.sprintId,
    points: input.points,
    dueDate: input.dueDate,
    createdAt: now,
    updatedAt: now,
    order: db.tickets.length + 1,
  }
  db.tickets.push(ticket)
  logActivity(ticket.id, "created", "created this ticket")
  audit("ticket.create", "Ticket", ticket.id)
  emit(
    workspaceRoomsForProject(projectId),
    "ticket.created",
    { ticket },
    currentUser().id
  )
  if (ticket.assigneeId && ticket.assigneeId !== currentUser().id) {
    createNotification(
      ticket.assigneeId,
      "ticket_assigned",
      `You were assigned ${ticket.shortId} — ${ticket.title}`,
      ticketLink(ticket)
    )
  }
  return ticket
}

export function updateTicket(id: string, patch: Partial<Ticket>): Ticket | null {
  const ticket = db.tickets.find((t) => t.id === id)
  if (!ticket) return null

  if (patch.status && patch.status !== ticket.status) {
    logActivity(
      id,
      "status_changed",
      `moved from ${ticket.status} to ${patch.status}`
    )
  }
  if (patch.assigneeId !== undefined && patch.assigneeId !== ticket.assigneeId) {
    const name = db.users.find((u) => u.id === patch.assigneeId)?.name ?? "Unassigned"
    logActivity(id, "assigned", `assigned to ${name}`)
  }
  if (patch.priority && patch.priority !== ticket.priority) {
    logActivity(id, "priority_changed", `priority set to ${patch.priority}`)
  }

  const assigneeChanged =
    patch.assigneeId !== undefined && patch.assigneeId !== ticket.assigneeId

  Object.assign(ticket, patch, { updatedAt: new Date().toISOString() })
  audit("ticket.update", "Ticket", id)
  emit(
    [`ticket:${id}`, ...workspaceRoomsForProject(ticket.projectId)],
    "ticket.updated",
    { ticket },
    currentUser().id
  )
  if (assigneeChanged && ticket.assigneeId && ticket.assigneeId !== currentUser().id) {
    createNotification(
      ticket.assigneeId,
      "ticket_assigned",
      `You were assigned ${ticket.shortId} — ${ticket.title}`,
      ticketLink(ticket)
    )
  }
  return ticket
}

export function deleteTicket(id: string): boolean {
  const idx = db.tickets.findIndex((t) => t.id === id)
  if (idx === -1) return false
  db.tickets.splice(idx, 1)
  db.comments = db.comments.filter((c) => c.ticketId !== id)
  db.activities = db.activities.filter((a) => a.ticketId !== id)
  audit("ticket.delete", "Ticket", id)
  return true
}

export function addComment(ticketId: string, content: string): Comment | null {
  const ticket = db.tickets.find((t) => t.id === ticketId)
  if (!ticket) return null
  const now = new Date().toISOString()
  const comment: Comment = {
    id: nextId("c"),
    content,
    ticketId,
    authorId: currentUser().id,
    createdAt: now,
    updatedAt: now,
  }
  db.comments.push(comment)
  logActivity(ticketId, "commented", "added a comment")
  emit(
    [`ticket:${ticketId}`, ...workspaceRoomsForProject(ticket.projectId)],
    "comment.added",
    { ticketId, comment },
    currentUser().id
  )
  // Notify the reporter and assignee (except the comment author).
  const actor = currentUser().id
  const recipients = new Set(
    [ticket.reporterId, ticket.assigneeId].filter(
      (uid): uid is string => !!uid && uid !== actor
    )
  )
  for (const uid of recipients) {
    createNotification(
      uid,
      "comment",
      `New comment on ${ticket.shortId} — ${ticket.title}`,
      ticketLink(ticket)
    )
  }
  return comment
}

export function createProject(
  workspaceId: string,
  input: Pick<Project, "name" | "shortCode" | "description"> &
    Partial<Project>
): Project {
  const project: Project = {
    id: nextId("p"),
    name: input.name,
    shortCode: input.shortCode.toUpperCase(),
    status: input.status ?? "PLANNING",
    workspaceId,
    description: input.description ?? "",
    startDate: input.startDate ?? new Date().toISOString(),
    endDate: input.endDate,
  }
  db.projects.push(project)
  audit("project.create", "Project", project.id)
  return project
}

export function reorderColumn(
  projectId: string,
  status: TicketStatus,
  orderedIds: string[]
) {
  orderedIds.forEach((id, index) => {
    const ticket = db.tickets.find((t) => t.id === id && t.projectId === projectId)
    if (ticket) {
      ticket.status = status
      ticket.order = index
      ticket.updatedAt = new Date().toISOString()
    }
  })
  emit(
    workspaceRoomsForProject(projectId),
    "board.reordered",
    { status, orderedIds },
    currentUser().id
  )
}

// --- Git / IDE (Phase 2) ----------------------------------------------------

function shortHash(): string {
  return Math.random().toString(16).slice(2, 9)
}

// Saves an in-IDE edit to the working tree. Marks the file modified (unless it
// was newly added) so the explorer and commit box reflect the pending change.
export function saveFile(
  workspaceId: string,
  path: string,
  content: string
): RepoFile | null {
  const file = db.repoFiles.find(
    (f) => f.workspaceId === workspaceId && f.path === path
  )
  if (!file) return null
  file.content = content
  if (file.status === "unmodified") {
    file.status = content === file.originalContent ? "unmodified" : "modified"
  }
  return file
}

export function createFile(
  workspaceId: string,
  path: string,
  content = ""
): RepoFile {
  const file: RepoFile = {
    id: nextId("rf"),
    workspaceId,
    path,
    content,
    originalContent: "",
    status: "untracked",
  }
  db.repoFiles.push(file)
  return file
}

// Commits the working changes: records a GitCommit, links a ticket if the
// message references one (e.g. "[ACME-142]"), and resets file statuses.
export function commitChanges(
  workspaceId: string,
  message: string,
  branch: string,
  paths?: string[]
): GitCommit | null {
  const changed = db.repoFiles.filter(
    (f) =>
      f.workspaceId === workspaceId &&
      f.status !== "unmodified" &&
      (!paths || paths.includes(f.path))
  )
  if (changed.length === 0) return null

  const ticketMatch = message.match(/\[([A-Z]+-\d+)\]/)
  const ticket = ticketMatch
    ? db.tickets.find((t) => t.shortId === ticketMatch[1])
    : undefined

  const commit: GitCommit = {
    id: nextId("g"),
    hash: shortHash(),
    message,
    authorId: currentUser().id,
    date: new Date().toISOString(),
    workspaceId,
    ticketId: ticket?.id,
    branch,
  }
  db.commits.push(commit)

  for (const file of changed) {
    file.originalContent = file.content
    file.status = "unmodified"
  }

  // Reflect the new commit on the branch's ahead count.
  const br = db.branches.find(
    (b) => b.workspaceId === workspaceId && b.name === branch
  )
  if (br) {
    br.ahead += 1
    br.lastCommitHash = commit.hash
    br.lastCommitDate = commit.date
    br.lastAuthorId = commit.authorId
  }

  audit("git.commit", "Workspace", workspaceId)
  emit(`ws:${workspaceId}`, "git.commit", { commit }, currentUser().id)
  if (ticket) {
    emit([`ticket:${ticket.id}`], "ticket.updated", { ticket })
  }
  return commit
}

export function createBranch(
  workspaceId: string,
  name: string,
  fromHash = "a1b2c3d"
): Branch {
  const branch: Branch = {
    id: nextId("br"),
    workspaceId,
    name,
    ahead: 0,
    behind: 0,
    protected: false,
    lastCommitHash: fromHash,
    lastCommitDate: new Date().toISOString(),
    lastAuthorId: currentUser().id,
  }
  db.branches.push(branch)
  audit("git.branch.create", "Workspace", workspaceId)
  return branch
}
</file>

