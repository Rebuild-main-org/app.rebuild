<file path="app/api/webhooks/github/[wsId]/route.ts">
import { currentUser, db, nextId } from "@/lib/db"
import { emit } from "@/lib/events"
import { createNotification } from "@/lib/mutations"
import type { CIStatus, Deployment, GitCommit } from "@/lib/types"

// POST /api/webhooks/github/:wsId — GitHub webhook receiver.
// Handles push, pull_request, check_run (CI) and release events, updates the
// store, and broadcasts realtime updates + notifications. Signature
// verification (X-Hub-Signature-256) would gate this in production.
export async function POST(
  request: Request,
  { params }: { params: Promise<{ wsId: string }> }
) {
  const { wsId } = await params
  const ws = db.workspaces.find((w) => w.id === wsId)
  if (!ws) return Response.json({ error: "Unknown workspace" }, { status: 404 })

  const eventType =
    request.headers.get("x-github-event") ??
    new URL(request.url).searchParams.get("event") ??
    "push"
  const body = (await request.json().catch(() => ({}))) as Record<
    string,
    unknown
  >
  const actor = currentUser()
  const now = new Date().toISOString()

  // Members to notify for team-wide events.
  const memberIds = db.members
    .filter((m) => m.workspaceId === wsId)
    .map((m) => m.userId)

  switch (eventType) {
    case "push": {
      const branch =
        (body.branch as string) ??
        (body.ref as string)?.replace("refs/heads/", "") ??
        "main"
      const message = (body.message as string) ?? "chore: update from GitHub"
      const commit: GitCommit = {
        id: nextId("g"),
        hash: Math.random().toString(16).slice(2, 9),
        message,
        authorId: actor.id,
        date: now,
        workspaceId: wsId,
        branch,
        ticketId: db.tickets.find((t) =>
          message.includes(`[${t.shortId}]`)
        )?.id,
      }
      db.commits.push(commit)
      emit(`ws:${wsId}`, "git.commit", { commit })
      return Response.json({ ok: true, commit })
    }

    case "pull_request": {
      const action = (body.action as string) ?? "opened"
      const number =
        (body.number as number) ??
        Math.max(0, ...db.prs.map((p) => p.number)) + 1
      let pr = db.prs.find((p) => p.workspaceId === wsId && p.number === number)
      if (!pr) {
        pr = {
          id: nextId("pr"),
          number,
          title: (body.title as string) ?? `PR #${number}`,
          status: "OPEN",
          ci: "RUNNING",
          branchFrom: (body.branchFrom as string) ?? "feature/x",
          branchTo: (body.branchTo as string) ?? "main",
          workspaceId: wsId,
          authorId: actor.id,
          createdAt: now,
        }
        db.prs.push(pr)
      }
      if (action === "closed") pr.status = "MERGED"
      emit(`ws:${wsId}`, "pr.updated", { pr })
      for (const uid of memberIds) {
        createNotification(
          uid,
          "pr",
          `PR #${pr.number} ${action} — ${pr.title}`,
          `/workspace/${wsId}/git`
        )
      }
      // When a PR merges, its linked ticket auto-moves to Done (spec §06).
      if (action === "closed" && pr.ticketId) {
        const ticket = db.tickets.find((t) => t.id === pr.ticketId)
        if (ticket) {
          ticket.status = "DONE"
          emit(
            [`ticket:${ticket.id}`, `project:${ticket.projectId}`, `ws:${wsId}`],
            "ticket.updated",
            { ticket }
          )
        }
      }
      return Response.json({ ok: true, pr })
    }

    case "check_run": {
      const conclusion = ((body.conclusion as string) ??
        "success") as "success" | "failure"
      const ci: CIStatus = conclusion === "success" ? "PASSING" : "FAILING"
      const number = body.prNumber as number | undefined
      const pr =
        db.prs.find((p) => p.workspaceId === wsId && p.number === number) ??
        db.prs.find((p) => p.workspaceId === wsId && p.status === "OPEN")
      if (pr) {
        pr.ci = ci
        emit(`ws:${wsId}`, "pr.updated", { pr })
        if (ci === "FAILING") {
          createNotification(
            pr.authorId,
            "ci_failed",
            `CI failed on PR #${pr.number} — ${pr.title}`,
            `/workspace/${wsId}/git`
          )
        }
      }
      return Response.json({ ok: true, ci })
    }

    case "release": {
      const deployment: Deployment = {
        id: nextId("d"),
        env: "PRODUCTION",
        commitHash:
          (body.commitHash as string) ??
          Math.random().toString(16).slice(2, 9),
        status: "SUCCESS",
        deployedAt: now,
        workspaceId: wsId,
        branch: "main",
        authorId: actor.id,
      }
      db.deployments.push(deployment)
      emit(`ws:${wsId}`, "deployment.created", { deployment })
      // Whole team + client notified of a production deploy (spec §10).
      const clientId = db.users.find((u) => u.email === ws.clientEmail)?.id
      for (const uid of [...memberIds, ...(clientId ? [clientId] : [])]) {
        createNotification(
          uid,
          "deploy_prod",
          `Production deploy succeeded for ${ws.name}`,
          `/workspace/${wsId}/git`
        )
      }
      return Response.json({ ok: true, deployment })
    }

    default:
      return Response.json({ ok: true, ignored: eventType })
  }
}
</file>

<file path="app/api/workspaces/[id]/meetings/route.ts">
import { currentUser, db, nextId, userById } from "@/lib/db"
import { emit } from "@/lib/events"
import { createNotification } from "@/lib/mutations"
import type { Meeting } from "@/lib/types"

export const dynamic = "force-dynamic"

// Generates a Google Meet-style link. With real Google OAuth credentials this
// would call the Calendar API to create a conference; here we mint a code.
function meetLink(): string {
  const seg = () =>
    Math.random().toString(36).replace(/[^a-z]/g, "").slice(0, 3) || "xyz"
  return `https://meet.google.com/${seg()}-${seg()}${seg()}-${seg()}`
}

export async function GET(
  _request: Request,
  { params }: { params: Promise<{ id: string }> }
) {
  const { id } = await params
  const meetings = db.meetings
    .filter((m) => m.workspaceId === id)
    .sort((a, b) => a.start.localeCompare(b.start))
    .map((m) => ({
      ...m,
      attendees: m.attendeeIds.map((uid) => userById(uid)?.name).filter(Boolean),
    }))
  return Response.json(meetings)
}

export async function POST(
  request: Request,
  { params }: { params: Promise<{ id: string }> }
) {
  const { id } = await params
  const user = currentUser()
  const body = (await request.json()) as Partial<Meeting>
  if (!body.title || !body.start) {
    return Response.json({ error: "title and start are required" }, { status: 400 })
  }
  const start = new Date(body.start)
  const end = body.end ? new Date(body.end) : new Date(start.getTime() + 3600_000)
  const meeting: Meeting = {
    id: nextId("mtg"),
    title: body.title,
    start: start.toISOString(),
    end: end.toISOString(),
    workspaceId: id,
    meetLink: body.meetLink || meetLink(),
    attendeeIds: body.attendeeIds?.length
      ? body.attendeeIds
      : db.members.filter((m) => m.workspaceId === id).map((m) => m.userId),
    createdById: user.id,
  }
  db.meetings.push(meeting)
  emit(`ws:${id}`, "meeting.created", { meeting }, user.id)
  for (const uid of meeting.attendeeIds) {
    if (uid !== user.id)
      createNotification(
        uid,
        "meeting",
        `Meeting scheduled: ${meeting.title} — ${start.toLocaleString()}`,
        `/workspace/${id}/calendar`
      )
  }
  return Response.json(meeting, { status: 201 })
}
