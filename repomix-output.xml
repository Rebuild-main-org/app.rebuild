// Derived selectors over the in-memory store. Pure reads — used by server
// components and route handlers alike.

import { db, userById } from "./db"
import {
  PRIORITY_META,
  type Project,
  type RepoFile,
  type Ticket,
  type TicketStatus,
  type TreeNode,
  type Workspace,
} from "./types"

export function getWorkspace(id: string): Workspace | undefined {
  return db.workspaces.find((w) => w.id === id)
}

export function getProject(id: string): Project | undefined {
  return db.projects.find((p) => p.id === id)
}

export function workspacesForUser(userId: string): Workspace[] {
  const wsIds = new Set(
    db.members.filter((m) => m.userId === userId).map((m) => m.workspaceId)
  )
  return db.workspaces.filter((w) => wsIds.has(w.id))
}

export function projectsForWorkspace(workspaceId: string): Project[] {
  return db.projects.filter((p) => p.workspaceId === workspaceId)
}

export function membersForWorkspace(workspaceId: string) {
  return db.members
    .filter((m) => m.workspaceId === workspaceId)
    .map((m) => ({ ...m, user: userById(m.userId)! }))
    .filter((m) => m.user)
}

export function ticketsForProject(projectId: string): Ticket[] {
  return db.tickets
    .filter((t) => t.projectId === projectId)
    .sort((a, b) => a.order - b.order)
}

export function ticketsForWorkspace(workspaceId: string): Ticket[] {
  const projectIds = new Set(
    projectsForWorkspace(workspaceId).map((p) => p.id)
  )
  return db.tickets.filter((t) => projectIds.has(t.projectId))
}

export function workspaceIdForProject(projectId: string): string | undefined {
  return getProject(projectId)?.workspaceId
}

export function ticketCountsByStatus(
  projectId: string
): Record<TicketStatus, number> {
  const counts = {
    BACKLOG: 0,
    TODO: 0,
    IN_PROGRESS: 0,
    IN_REVIEW: 0,
    DONE: 0,
  } as Record<TicketStatus, number>
  for (const t of ticketsForProject(projectId)) counts[t.status] += 1
  return counts
}

export function activeWorkloadByUser(workspaceId: string) {
  const tickets = ticketsForWorkspace(workspaceId).filter(
    (t) => t.status === "IN_PROGRESS" || t.status === "IN_REVIEW"
  )
  const map = new Map<string, number>()
  for (const t of tickets) {
    if (!t.assigneeId) continue
    map.set(t.assigneeId, (map.get(t.assigneeId) ?? 0) + 1)
  }
  return map
}

// Engineer dashboard selectors -------------------------------------------------

export function myTickets(userId: string): Ticket[] {
  return db.tickets.filter((t) => t.assigneeId === userId)
}

export function todaysFocus(userId: string): Ticket[] {
  const mine = myTickets(userId)
  const inProgress = mine.filter((t) => t.status === "IN_PROGRESS")
  const urgentNotStarted = mine.filter(
    (t) =>
      (t.priority === "CRITICAL" || t.priority === "HIGH") &&
      (t.status === "TODO" || t.status === "BACKLOG")
  )
  const dueSoon = mine.filter((t) => {
    if (!t.dueDate || t.status === "DONE") return false
    const days = (new Date(t.dueDate).getTime() - Date.now()) / 86_400_000
    return days <= 2
  })
  const seen = new Set<string>()
  return [...inProgress, ...urgentNotStarted, ...dueSoon]
    .filter((t) => (seen.has(t.id) ? false : (seen.add(t.id), true)))
    .sort(
      (a, b) =>
        PRIORITY_META[a.priority].rank - PRIORITY_META[b.priority].rank
    )
}

export function milestoneProgress(projectId: string, milestoneId: string) {
  const tickets = db.tickets.filter((t) => t.milestoneId === milestoneId)
  if (tickets.length === 0) return 0
  const done = tickets.filter((t) => t.status === "DONE").length
  return Math.round((done / tickets.length) * 100)
}

export function projectProgress(projectId: string): number {
  const tickets = ticketsForProject(projectId)
  if (tickets.length === 0) return 0
  const done = tickets.filter((t) => t.status === "DONE").length
  return Math.round((done / tickets.length) * 100)
}

// Git / IDE selectors ----------------------------------------------------------

export function repoFiles(workspaceId: string): RepoFile[] {
  return db.repoFiles
    .filter((f) => f.workspaceId === workspaceId)
    .sort((a, b) => a.path.localeCompare(b.path))
}

export function getRepoFile(
  workspaceId: string,
  path: string
): RepoFile | undefined {
  return db.repoFiles.find(
    (f) => f.workspaceId === workspaceId && f.path === path
  )
}

export function branchesForWorkspace(workspaceId: string) {
  return db.branches.filter((b) => b.workspaceId === workspaceId)
}

// Builds a nested directory tree from the flat list of repo file paths.
export function buildTree(workspaceId: string): TreeNode[] {
  const files = repoFiles(workspaceId)
  const root: TreeNode[] = []

  for (const file of files) {
    const parts = file.path.split("/")
    let level = root
    let acc = ""
    parts.forEach((name, idx) => {
      acc = acc ? `${acc}/${name}` : name
      const isLeaf = idx === parts.length - 1
      let node = level.find((n) => n.name === name)
      if (!node) {
        node = {
          name,
          path: acc,
          type: isLeaf ? "file" : "dir",
          ...(isLeaf ? { status: file.status } : { children: [] }),
        }
        level.push(node)
      }
      if (!isLeaf) level = node.children!
    })
  }

  // Sort: directories first, then files, alphabetically.
  const sortLevel = (nodes: TreeNode[]) => {
    nodes.sort((a, b) => {
      if (a.type !== b.type) return a.type === "dir" ? -1 : 1
      return a.name.localeCompare(b.name)
    })
    nodes.forEach((n) => n.children && sortLevel(n.children))
  }
  sortLevel(root)
  return root
}
