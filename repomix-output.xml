<file path="components/ide/file-tree.tsx">
"use client"

import { useState } from "react"
import {
  ChevronDown,
  ChevronRight,
  File,
  FileCode,
  FileJson,
  FileText,
  Folder,
  FolderOpen,
} from "lucide-react"

import { FILE_STATUS_META, type TreeNode } from "@/lib/types"
import { cn } from "@/lib/utils"

function FileGlyph({ name }: { name: string }) {
  const className = "text-muted-foreground size-4 shrink-0"
  if (name.endsWith(".json")) return <FileJson className={className} />
  if (name.endsWith(".md")) return <FileText className={className} />
  if (/\.(tsx?|jsx?|css|mjs)$/.test(name))
    return <FileCode className={className} />
  return <File className={className} />
}

function Node({
  node,
  depth,
  activePath,
  onOpen,
}: {
  node: TreeNode
  depth: number
  activePath: string | null
  onOpen: (path: string) => void
}) {
  const [open, setOpen] = useState(depth < 1)
  const pad = { paddingLeft: `${depth * 12 + 8}px` }

  if (node.type === "dir") {
    const Icon = open ? FolderOpen : Folder
    const Chevron = open ? ChevronDown : ChevronRight
    return (
      <div>
        <button
          onClick={() => setOpen((o) => !o)}
          style={pad}
          className="hover:bg-muted/60 flex w-full items-center gap-1 py-1 text-left text-sm"
        >
          <Chevron className="text-muted-foreground size-3.5 shrink-0" />
          <Icon className="size-4 shrink-0 text-sky-500" />
          <span className="truncate">{node.name}</span>
        </button>
        {open &&
          node.children?.map((child) => (
            <Node
              key={child.path}
              node={child}
              depth={depth + 1}
              activePath={activePath}
              onOpen={onOpen}
            />
          ))}
      </div>
    )
  }

  const status = node.status ?? "unmodified"
  const meta = FILE_STATUS_META[status]
  return (
    <button
      onClick={() => onOpen(node.path)}
      style={pad}
      className={cn(
        "hover:bg-muted/60 flex w-full items-center gap-1.5 py-1 pr-2 text-left text-sm",
        activePath === node.path && "bg-muted"
      )}
    >
      <span className="w-3.5 shrink-0" />
      <FileGlyph name={node.name} />
      <span
        className={cn(
          "truncate",
          status === "modified" && "text-amber-600 dark:text-amber-400",
          (status === "added" || status === "untracked") &&
            "text-emerald-600 dark:text-emerald-400"
        )}
      >
        {node.name}
      </span>
      {meta.letter && (
        <span className={cn("ml-auto text-xs font-bold", meta.color)}>
          {meta.letter}
        </span>
      )}
    </button>
  )
}

export function FileTree({
  tree,
  activePath,
  onOpen,
}: {
  tree: TreeNode[]
  activePath: string | null
  onOpen: (path: string) => void
}) {
  return (
    <div className="py-1">
      {tree.map((node) => (
        <Node
          key={node.path}
          node={node}
          depth={0}
          activePath={activePath}
          onOpen={onOpen}
        />
      ))}
    </div>
  )
}
