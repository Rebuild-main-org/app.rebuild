{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SpecCritiqueResult",
  "description": "Résultat structuré du gate de critique de spec (étape 3). readiness=READY ssi aucun BLOCKER et aucune question bloquante ouverte.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "readiness",
    "spec_quality_score",
    "summary",
    "findings",
    "open_questions",
    "assumptions_to_confirm",
    "resolved",
    "next_action"
  ],
  "properties": {
    "readiness": {
      "type": "string",
      "enum": ["READY", "BLOCK"],
      "description": "Verdict du gate. BLOCK tant qu'il reste un BLOCKER ou une question bloquante non résolue."
    },
    "spec_quality_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Maturité globale de la spec (0-100)."
    },
    "summary": {
      "type": "string",
      "description": "Synthèse en une à trois phrases (langue = output_language)."
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "category",
          "severity",
          "spec_path",
          "problem",
          "why_it_matters",
          "suggested_resolution",
          "requires_human"
        ],
        "properties": {
          "id": { "type": "string", "description": "Identifiant stable, ex. F-001." },
          "category": {
            "type": "string",
            "enum": [
              "completeness",
              "consistency",
              "realism",
              "data_access",
              "integrations",
              "security_compliance",
              "testability",
              "ambiguity"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["BLOCKER", "MAJOR", "MINOR", "INFO"]
          },
          "spec_path": {
            "type": "string",
            "description": "Chemin dans la spec, ex. nfr.latency_budgets_ms[0] ou data.entities[trip].access_patterns."
          },
          "problem": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "suggested_resolution": { "type": "string" },
          "requires_human": {
            "type": "boolean",
            "description": "true si une décision humaine est nécessaire (vs corrigeable automatiquement)."
          }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "question", "why_needed", "blocking", "proposed_default"],
        "properties": {
          "id": { "type": "string", "description": "Identifiant stable, ex. Q-001." },
          "question": { "type": "string" },
          "why_needed": { "type": "string" },
          "blocking": {
            "type": "boolean",
            "description": "true si l'absence de réponse force readiness=BLOCK."
          },
          "proposed_default": {
            "type": ["string", "null"],
            "description": "Défaut proposé (assumption) ou null si aucun défaut raisonnable."
          }
        }
      }
    },
    "assumptions_to_confirm": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "assumption", "impact_if_wrong"],
        "properties": {
          "id": { "type": "string", "description": "Identifiant stable, ex. A-001." },
          "assumption": { "type": "string" },
          "impact_if_wrong": { "type": "string" }
        }
      }
    },
    "resolved": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ids des findings/questions résolus par les réponses humaines de ce tour."
    },
    "next_action": {
      "type": "string",
      "description": "Ce que l'humain doit faire pour avancer (langue = output_language)."
    }
  }
}
